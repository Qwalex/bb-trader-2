{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "docker/node-base.Dockerfile",
    "watchPatterns": [
      "apps/classifier/**",
      "packages/**",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "package.json",
      "turbo.json",
      "tsconfig.base.json"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter @app/classifier start",
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE"
  }
}
