{
  "name": "@app/userbot",
  "version": "0.0.0",
  "private": true,
  "description": "Python+Telethon userbot. pnpm-scripts просто вызывают uv/python.",
  "scripts": {
    "dev": "uv run python -m bb_userbot.main",
    "build": "node -e \"process.exit(0)\"",
    "typecheck": "node scripts/uv-optional.mjs mypy src/bb_userbot",
    "lint": "node scripts/uv-optional.mjs ruff check src/bb_userbot",
    "format": "node scripts/uv-optional.mjs ruff format src/bb_userbot"
  }
}
