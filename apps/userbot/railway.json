{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "docker/userbot.Dockerfile",
    "watchPatterns": [
      "apps/userbot/**"
    ]
  },
  "deploy": {
    "startCommand": "/app/.venv/bin/python -m bb_userbot.main",
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE"
  }
}
