{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "docker/node-base.Dockerfile",
    "buildArgs": {
      "APP_NAME": "@app/api",
      "APP_DIR": "apps/api"
    },
    "watchPatterns": [
      "apps/api/**",
      "packages/**",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "package.json",
      "turbo.json",
      "tsconfig.base.json"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter @app/api start",
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "healthcheckPath": "/auth/me",
    "healthcheckTimeout": 30
  }
}
