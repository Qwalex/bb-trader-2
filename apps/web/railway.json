{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "docker/node-base.Dockerfile",
    "watchPatterns": [
      "apps/web/**",
      "packages/shared-ts/**",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "package.json",
      "turbo.json",
      "tsconfig.base.json"
    ]
  },
  "deploy": {
    "startCommand": "pnpm start",
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 120
  }
}
