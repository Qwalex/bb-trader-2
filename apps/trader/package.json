{
  "name": "@app/trader",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
