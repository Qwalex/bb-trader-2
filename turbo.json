{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalDependencies": [".env", ".env.example", "tsconfig.base.json"],
  "globalEnv": ["NODE_ENV", "DATABASE_URL", "APP_ENCRYPTION_KEY"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "node_modules/.prisma/**"],
      "inputs": [
        "src/**",
        "prisma/**",
        "app/**",
        "public/**",
        "tsconfig.json",
        "package.json",
        "next.config.*",
        "tsconfig.*.json"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "db:generate": {
      "cache": false,
      "outputs": ["node_modules/.prisma/**"]
    }
  }
}
