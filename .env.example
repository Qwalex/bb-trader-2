# === Core ===

# Postgres (local: поднять docker-compose.dev.yml)
DATABASE_URL=postgresql://bb:bb@localhost:5432/bb?schema=public

# AES-GCM ключ для шифрования секретов at rest (Bybit apiSecret, Telethon sessionString).
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_ENCRYPTION_KEY=

# NODE_ENV=development
LOG_LEVEL=info

# === api (apps/api) ===

# Первый логин с таким Telegram user id получит роль admin (bootstrap).
INITIAL_ADMIN_TELEGRAM_ID=

# Секрет для подписи session cookie (любая длинная случайная строка).
SESSION_SECRET=

# Разрешённые origin'ы для CORS, через запятую.
API_CORS_ORIGINS=http://localhost:3000

# Порты (локально). На Railway используется PORT автоматически.
API_PORT=3001

# === web (apps/web) ===

NEXT_PUBLIC_API_URL=http://localhost:3001
WEB_PORT=3000

# === Telegram ===

# Токен бота для Telegram Login Widget и подтверждения сигналов в чате.
TELEGRAM_BOT_TOKEN=

# API credentials для userbot (Telethon). Получить на https://my.telegram.org
TELEGRAM_USERBOT_API_ID=
TELEGRAM_USERBOT_API_HASH=

# === OpenRouter (classifier) ===

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_HTTP_TIMEOUT_MS=180000

# === Observability / misc ===

# Включение записи в таблицу AppLog.
APPLOG_ENABLED=true

# Общие крон'ы (trader) — таймаут опроса позиций.
POLL_CABINET_POSITIONS_CRON=*/30 * * * * *
